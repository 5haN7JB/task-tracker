{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development DATABASE_URL=${DATABASE_URL:-file:../../db.sqlite} PORT=${PORT:-26123} && corepack pnpm run build && corepack pnpm run start",
    "build": "node ./build.mjs",
    "start": "export DATABASE_URL=${DATABASE_URL:-file:../../db.sqlite} PORT=${PORT:-26123} && node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/express-session": "^1.18.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-session": "^1.19.0",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
